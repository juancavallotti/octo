project_id = "your-gcp-project-id"

# Must match the k3s deployment.
domain = "octo.juancavallotti.com"

# What to deploy (bump and re-apply to roll an upgrade):
image_tag     = "latest" # or a published git tag, e.g. "v0.1.1"
chart_version = "0.1.1"   # must match the pushed helm/Chart.yaml

# Optional overrides (defaults shown):
# region        = "us-west1"
# zone          = "us-west1-a"
# instance_name = "octo"
# repository_id = "octo"
# kubeconfig    = ""        # empty = ../k3s/kubeconfig.yaml (from `task deploy:kubeconfig`)
