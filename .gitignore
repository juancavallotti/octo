bin/
dist/
# Postgres data dir for the local k3d dev cluster, host-mounted into the node
# (see deploy/k3d/cluster.yaml). Keep the dir (data/.gitkeep) but never its data.
/data/*
!/data/.gitkeep
# Rendered runtime configs the editor writes for `octo -watch` (dev RUN feature).
/.octo-run/
# Local flow YAML the standalone app reads/writes under `task dev`.
/.octo-flows/
# Go build output left in a module dir by `go build` without -o (binary named
# after the package dir, e.g. runtime/cli/cli). The canonical output is bin/.
/runtime/cli/cli
/orchestrator/orchestrator
# DevSpace's local state/cache dir.
/.devspace/
*.log
*.tmp
*.swp
.DS_Store
__debug_bin*
*.go.test
node_modules
*.tsbuildinfo
